---
interface Props {
  size?: number;
}
const { size = 26 } = Astro.props;
---

<span class="brand-mark" aria-hidden="true" style={`width:${size}px;height:${size}px`}>
  <svg viewBox="0 0 64 64">
    <g fill="var(--brand-600)" opacity="0.50">
      <circle cx="16" cy="16" r="3.2"></circle>
      <circle cx="32" cy="16" r="3.2"></circle>
      <circle cx="48" cy="16" r="3.2"></circle>
      <circle cx="16" cy="32" r="3.2"></circle>
      <circle cx="48" cy="32" r="3.2"></circle>
      <circle cx="16" cy="48" r="3.2"></circle>
      <circle cx="32" cy="48" r="3.2"></circle>
      <circle cx="48" cy="48" r="3.2"></circle>
    </g>
    <circle cx="32" cy="32" r="6.5" fill="var(--brand-600)"></circle>
  </svg>
</span>
