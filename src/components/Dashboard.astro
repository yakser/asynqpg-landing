---
type RowStatus = "pending" | "running" | "completed" | "failed" | "cancelled";
type Row = { id: string; type: string; status: RowStatus; attempts: string; created: string };

const rows: Row[] = [
  { id: "#48201", type: "email:send", status: "running", attempts: "0/5", created: "2s ago" },
  { id: "#48200", type: "report:generate", status: "pending", attempts: "0/3", created: "4s ago" },
  { id: "#48199", type: "webhook:deliver", status: "failed", attempts: "3/3", created: "11s ago" },
  { id: "#48198", type: "email:send", status: "completed", attempts: "1/5", created: "14s ago" },
  { id: "#48197", type: "image:resize", status: "completed", attempts: "1/3", created: "18s ago" },
  {
    id: "#48196",
    type: "notification:push",
    status: "cancelled",
    attempts: "0/3",
    created: "22s ago",
  },
];
---

<section class="section" id="dashboard" aria-labelledby="dashboard-heading">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">Web UI</span>
        <h2 id="dashboard-heading">A dashboard for the table.</h2>
      </div>
      <p class="lede">
        An embedded React SPA. Mount it as an HTTP handler, or run the standalone binary. Basic Auth
        or GitHub OAuth, your choice.
      </p>
    </div>

    <div
      class="dashpeek"
      role="img"
      aria-label="Preview of the asynqpg web dashboard showing task statistics and a list of recent tasks with their status"
    >
      <div class="dashpeek-bar" aria-hidden="true">
        <span class="dashpeek-dot dashpeek-dot--red"></span>
        <span class="dashpeek-dot dashpeek-dot--amber"></span>
        <span class="dashpeek-dot dashpeek-dot--green"></span>
        <span class="dashpeek-url">localhost:8080/asynqpg/tasks?status=running</span>
      </div>
      <div class="dashpeek-body" aria-hidden="true">
        <div class="dashpeek-stats">
          <div class="dashpeek-stat">
            <div class="lbl">enqueued · 24h</div><div class="num">128,402</div>
          </div>
          <div class="dashpeek-stat">
            <div class="lbl">running</div><div class="num running">42</div>
          </div>
          <div class="dashpeek-stat">
            <div class="lbl">completed</div><div class="num completed">126,781</div>
          </div>
          <div class="dashpeek-stat">
            <div class="lbl">failed</div><div class="num failed">214</div>
          </div>
        </div>

        <div class="dashpeek-table">
          <div class="dashpeek-row head">
            <div>id</div><div>type</div><div>status</div><div>attempts</div><div>created</div>
          </div>
          {
            rows.map((r) => (
              <div class="dashpeek-row">
                <div>{r.id}</div>
                <div>{r.type}</div>
                <div>
                  <span class={`chip ${r.status}`}>
                    <span class="dot" aria-hidden="true" />
                    {r.status}
                  </span>
                </div>
                <div>{r.attempts}</div>
                <div>{r.created}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="callout is-spaced">
      <div class="bar"></div>
      <div class="body">
        <b>Note.</b> The dashboard ships as a separate Go module so its frontend dependencies don't leak
        into your service. Mount it under any prefix.
      </div>
    </div>
  </div>
</section>
