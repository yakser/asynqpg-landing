---
type TabId = "overview" | "tasks" | "task-detail" | "workers" | "maintenance";

type Tab = {
  id: TabId;
  label: string;
  src: string;
  alt: string;
  caption: string;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const tabs: Tab[] = [
  {
    id: "overview",
    label: "Overview",
    src: `${base}/assets/screenshots/overview.png`,
    alt: "asynqpg Overview page – KPI strip with pending, running, failed, completed and cancelled counts; per-type queue cards sorted by failed desc.",
    caption:
      "Five live KPIs across all task types. Per-type cards show pending/running/done/failed/cancelled counts and link straight into the filtered Tasks list. Auto-refresh every 5s.",
  },
  {
    id: "tasks",
    label: "Tasks",
    src: `${base}/assets/screenshots/tasks.png`,
    alt: "asynqpg Tasks list page with saved views, filter pills, search bar and a table of recent tasks.",
    caption:
      "Saved views (All · Pending · Running · Failed · Needs retry · Dead-letter), filter pills for type/status/idempotency, full-text search, and j/k keyboard navigation. Bulk-select rows to retry, cancel, or delete.",
  },
  {
    id: "task-detail",
    label: "Task detail",
    src: `${base}/assets/screenshots/task-detail.png`,
    alt: "Task detail drawer with tabs for payload, attempts, timing, related tasks and the raw row.",
    caption:
      "Side drawer with Payload, Attempts (every error trace + duration), Timing breakdown, Related tasks, and the Raw row. Copy curl, retry, or delete from the footer – no SQL required.",
  },
  {
    id: "workers",
    label: "Workers",
    src: `${base}/assets/screenshots/workers.png`,
    alt: "asynqpg Workers page showing the elected leader and a live snapshot of currently processing tasks.",
    caption:
      "The elected leader, lease TTL, and a live snapshot of every task currently in the running state – with attempt counts and seconds-since-pickup. Click any row to jump to its detail.",
  },
  {
    id: "maintenance",
    label: "Maintenance",
    src: `${base}/assets/screenshots/maintenance.png`,
    alt: "asynqpg Maintenance page with leader card, pending/running/failed/dead-letter KPIs, recent failures and background-task descriptions.",
    caption:
      "Leader-elected background tasks (Rescuer, Cleaner, Leader election) with their lease state, dead-letter count, and the most recent failures – the page operators look at first when something is off.",
  },
];

const featureChips = [
  "5 KPIs",
  "per-type cards",
  "saved views",
  "bulk retry / cancel / delete",
  "task drawer",
  "cmd-K palette",
  "j / k navigation",
  "OAuth + Basic Auth",
  "light / dark / system",
];
---

<section class="section" id="dashboard" aria-labelledby="dashboard-heading">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">Web UI</span>
        <h2 id="dashboard-heading">A dashboard built for operators.</h2>
      </div>
      <p class="lede">
        An embedded React SPA. Mount it as an HTTP handler under any prefix, or run the standalone
        binary. Basic Auth or pluggable OAuth providers, your choice.
      </p>
    </div>

    <div class="dash-chips" aria-hidden="true">
      {featureChips.map((c) => <span class="dash-chip">{c}</span>)}
    </div>

    <div class="dash-tabs" data-dashtabs>
      <div class="dash-tablist" role="tablist" aria-label="Dashboard screens">
        {
          tabs.map((t, i) => (
            <button
              class={`dash-tab${i === 0 ? " active" : ""}`}
              data-tab={t.id}
              role="tab"
              type="button"
              id={`dash-tab-${t.id}`}
              aria-controls={`dash-panel-${t.id}`}
              aria-selected={i === 0 ? "true" : "false"}
              tabindex={i === 0 ? 0 : -1}
            >
              {t.label}
            </button>
          ))
        }
      </div>

      {
        tabs.map((t, i) => (
          <div
            class={`dash-panel${i === 0 ? " active" : ""}`}
            data-tab={t.id}
            role="tabpanel"
            id={`dash-panel-${t.id}`}
            aria-labelledby={`dash-tab-${t.id}`}
            hidden={i === 0 ? undefined : true}
          >
            <div class="dash-shot">
              <div class="dash-shot-bar" aria-hidden="true">
                <span class="dash-shot-dot dash-shot-dot--red" />
                <span class="dash-shot-dot dash-shot-dot--amber" />
                <span class="dash-shot-dot dash-shot-dot--green" />
                <span class="dash-shot-url">localhost:8080/asynqpg/{t.id === "task-detail" ? "tasks" : t.id}</span>
              </div>
              <img
                src={t.src}
                alt={t.alt}
                width="1440"
                height="900"
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
                fetchpriority={i === 0 ? "high" : "auto"}
              />
            </div>
            <p class="dash-caption">{t.caption}</p>
          </div>
        ))
      }
    </div>

    <div class="callout is-spaced">
      <div class="bar"></div>
      <div class="body">
        <b>Note.</b> The dashboard ships as a separate Go module so its frontend dependencies don't leak
        into your service. Mount it under any prefix, behind your own router and middleware.
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-dashtabs]").forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>(".dash-tab"));
    const panels = Array.from(root.querySelectorAll<HTMLElement>(".dash-panel"));

    const activate = (btn: HTMLButtonElement, focus = false) => {
      const id = btn.dataset.tab;
      tabs.forEach((b) => {
        const isActive = b === btn;
        b.classList.toggle("active", isActive);
        b.setAttribute("aria-selected", isActive ? "true" : "false");
        b.setAttribute("tabindex", isActive ? "0" : "-1");
      });
      panels.forEach((p) => {
        const isActive = p.dataset.tab === id;
        p.classList.toggle("active", isActive);
        if (isActive) p.removeAttribute("hidden");
        else p.setAttribute("hidden", "");
      });
      if (focus) btn.focus();
    };

    tabs.forEach((btn) => {
      btn.addEventListener("click", () => activate(btn));
      btn.addEventListener("keydown", (e) => {
        const idx = tabs.indexOf(btn);
        if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
          e.preventDefault();
          const dir = e.key === "ArrowRight" ? 1 : -1;
          const next = tabs[(idx + dir + tabs.length) % tabs.length];
          activate(next, true);
        } else if (e.key === "Home") {
          e.preventDefault();
          activate(tabs[0], true);
        } else if (e.key === "End") {
          e.preventDefault();
          activate(tabs[tabs.length - 1], true);
        }
      });
    });
  });
</script>
